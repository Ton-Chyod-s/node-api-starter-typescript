# ==============================================================================
# DESENVOLVIMENTO LOCAL — .env.development
# ==============================================================================
# Copie: cp .env.development.example .env.development
# Este arquivo é carregado automaticamente quando NODE_ENV=development

APP_NAME=clean-arch-api
NODE_ENV=development
PORT=3000

# ------------------------------------------------------------------------------
# DATABASE (local / Docker)
# ------------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# ------------------------------------------------------------------------------
# JWT
# ------------------------------------------------------------------------------
KEY_JWT=dev-secret-troque-em-producao
JWT_EXPIRES_IN=1d
JWT_ISSUER=clean-arch-backend
JWT_AUDIENCE=clean-arch-backend

# ------------------------------------------------------------------------------
# CORS
# ------------------------------------------------------------------------------
CORS_ORIGIN=http://localhost:3001

# ------------------------------------------------------------------------------
# COOKIES & CSRF
# ------------------------------------------------------------------------------
COOKIE_SAMESITE=lax
COOKIE_SECURE=false
CSRF_ENABLED=true
CSRF_COOKIE_NAME=csrfToken

# ------------------------------------------------------------------------------
# PROXY
# ------------------------------------------------------------------------------
TRUST_PROXY=0

# ------------------------------------------------------------------------------
# SENTRY
# ------------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0

# ------------------------------------------------------------------------------
# SMTP (pode usar Mailtrap, Mailpit ou outro fake SMTP local)
# ------------------------------------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=no-reply@localhost

# ------------------------------------------------------------------------------
# PASSWORD RESET
# ------------------------------------------------------------------------------
FRONTEND_URL=http://localhost:3001
PASSWORD_RESET_PATH=/reset-password/{token}
PASSWORD_RESET_TOKEN_TTL_MINUTES=15

# ------------------------------------------------------------------------------
# SEED
# ------------------------------------------------------------------------------
SEED_ADMIN_EMAIL=admin@local.test
SEED_ADMIN_PASSWORD=ChangeMe!123
SEED_ADMIN_NAME=Admin

# ------------------------------------------------------------------------------
# DEBUG & LOGS
# ------------------------------------------------------------------------------
PRISMA_QUERY_LOG=false
DEBUG_ROUTES_ENABLED=false

# ------------------------------------------------------------------------------
# REDIS
# ------------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# TTL do cache de usuário em segundos (default: 60, min: 10, max: 3600)
# Requer REDIS_URL configurado. Ignorado se Redis não estiver disponível (NullCacheService).
USER_CACHE_TTL_SECONDS=60

# ------------------------------------------------------------------------------
# GOOGLE OAUTH (opcional em desenvolvimento)
# ------------------------------------------------------------------------------
# Crie credenciais em: https://console.cloud.google.com/apis/credentials
# URI de redirect deve ser registrado no Google Cloud Console
GOOGLE_CLIENT_ID=seu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

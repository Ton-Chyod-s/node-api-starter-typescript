# ==============================================================================
# PRODUÇÃO — .env.production
# ==============================================================================
# Copie: cp .env.production.example .env.production
# ATENÇÃO: nunca versione este arquivo com valores reais.
# Em Docker/CI, prefira injetar variáveis diretamente no container.

NODE_ENV=production
PORT=3000

# ------------------------------------------------------------------------------
# DATABASE
# ------------------------------------------------------------------------------
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

DATABASE_URL=postgresql://user:password@host:5432/database

# ------------------------------------------------------------------------------
# JWT — use um segredo forte e único por ambiente
# ------------------------------------------------------------------------------
KEY_JWT=
JWT_EXPIRES_IN=1d
JWT_ISSUER=clean-arch-backend
JWT_AUDIENCE=clean-arch-backend

# ------------------------------------------------------------------------------
# CORS — nunca use * em produção com credentials=true
# ------------------------------------------------------------------------------
CORS_ORIGIN=https://seu-dominio.com

# ------------------------------------------------------------------------------
# COOKIES & CSRF
# ------------------------------------------------------------------------------
COOKIE_SAMESITE=lax
COOKIE_SECURE=true   # obrigatório em HTTPS
CSRF_ENABLED=true
CSRF_COOKIE_NAME=csrfToken

# ------------------------------------------------------------------------------
# PROXY — ajuste conforme sua infraestrutura (NGINX, Cloudflare, etc.)
# ------------------------------------------------------------------------------
TRUST_PROXY=1

# ------------------------------------------------------------------------------
# SENTRY
# ------------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1  # ex: 10% das transações

# ------------------------------------------------------------------------------
# SMTP
# ------------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=no-reply@seu-dominio.com

# ------------------------------------------------------------------------------
# PASSWORD RESET
# ------------------------------------------------------------------------------
FRONTEND_URL=https://seu-dominio.com
PASSWORD_RESET_PATH=/reset-password/{token}
PASSWORD_RESET_TOKEN_TTL_MINUTES=15

# ------------------------------------------------------------------------------
# SEED — defina antes de rodar npm run db:seed em produção
# ------------------------------------------------------------------------------
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=Admin

# ------------------------------------------------------------------------------
# DEBUG & LOGS — mantenha desabilitado em produção
# ------------------------------------------------------------------------------
PRISMA_QUERY_LOG=false
DEBUG_ROUTES_ENABLED=false

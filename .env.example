# ==============================================================================
# TEMPLATE DE VARIÁVEIS DE AMBIENTE
# ==============================================================================
# Copie para .env.development ou .env.production e preencha os valores.
# O app carrega automaticamente o arquivo correto conforme NODE_ENV.
#
#   cp .env.example .env.development   # para desenvolvimento local
#   cp .env.example .env.production    # para produção
#
# Em Docker/CI, prefira injetar as variáveis diretamente no container.

# ------------------------------------------------------------------------------
# AMBIENTE
# ------------------------------------------------------------------------------
APP_NAME=clean-arch-api
NODE_ENV=development  # development | production | test
PORT=3000

# ------------------------------------------------------------------------------
# DATABASE
# ------------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# Connection string completa
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# ------------------------------------------------------------------------------
# AUTENTICAÇÃO JWT
# ------------------------------------------------------------------------------
KEY_JWT=troque-esta-chave-por-um-segredo-forte
# Pode ser número (segundos) ou formato do pacote `ms`: 3600, 1d, 2h, 15m
JWT_EXPIRES_IN=1d
JWT_ISSUER=clean-arch-backend
JWT_AUDIENCE=clean-arch-backend

# ------------------------------------------------------------------------------
# CORS
# ------------------------------------------------------------------------------
# Pode ser uma origem única ou múltiplas separadas por vírgula
# NUNCA use * em produção com credentials=true
CORS_ORIGIN=http://localhost:3001

# ------------------------------------------------------------------------------
# COOKIES & CSRF
# ------------------------------------------------------------------------------
COOKIE_SAMESITE=lax    # lax | strict | none
COOKIE_SECURE=false    # true em produção (HTTPS); obrigatório se SameSite=none
CSRF_ENABLED=true      # recomendado com auth via cookie
CSRF_COOKIE_NAME=csrfToken

# ------------------------------------------------------------------------------
# PROXY
# ------------------------------------------------------------------------------
# Se estiver atrás de NGINX, Cloudflare, etc.
# Exemplos: 0, 1, 2, true, loopback
TRUST_PROXY=0

# ------------------------------------------------------------------------------
# SENTRY (Monitoramento de Erros)
# ------------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0  # 0 = desabilitado, 1 = 100%

# ------------------------------------------------------------------------------
# SMTP (Envio de E-mails)
# ------------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=       # true | false (se vazio, infere: 465=true, resto=false)
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=        # ex: no-reply@seu-dominio.com

# ------------------------------------------------------------------------------
# PASSWORD RESET
# ------------------------------------------------------------------------------
FRONTEND_URL=http://localhost:3001
PASSWORD_RESET_PATH=/reset-password/{token}
PASSWORD_RESET_TOKEN_TTL_MINUTES=15

# ------------------------------------------------------------------------------
# SEED (Usuário Admin)
# ------------------------------------------------------------------------------
# Em produção, defina estes valores antes de rodar: npm run db:seed
SEED_ADMIN_EMAIL=admin@local.test
SEED_ADMIN_PASSWORD=ChangeMe!123
SEED_ADMIN_NAME=Admin

# ------------------------------------------------------------------------------
# DEBUG & LOGS
# ------------------------------------------------------------------------------
# Ativa log de queries SQL do Prisma (apenas em desenvolvimento)
PRISMA_QUERY_LOG=false
# Ativa rotas de debug (ex: /api/debug-sentry)
DEBUG_ROUTES_ENABLED=false

# ------------------------------------------------------------------------------
# REDIS
# ------------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

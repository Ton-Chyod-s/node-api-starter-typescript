{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "skipLibCheck": true,

    "baseUrl": ".",
    "paths": {
      "@config/*": ["src/config/*"],
      "@infrastructure/*": ["src/infrastructure/*"],
      "@interfaces/*": ["src/interfaces/*"],
      "@usecases/*": ["src/usecases/*"],
      "@domain/*": ["src/domain/*"],
      "@utils/*": ["src/utils/*"],
      "@main/*": ["src/main/*"],
      "@certs/*": ["src/certs/*"]
    },

    "noEmit": true
  },
  "include": [
    "src/**/*.ts",
    "tests/**/*.ts",
    "scripts/**/*.ts",
    "prisma.config.ts",
    "prisma/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
